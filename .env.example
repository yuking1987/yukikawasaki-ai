# === yukikawasaki-ai 環境変数サンプル ===
# 実際の値は .env にコピーして記入してください（.env はGit追跡されません）。

# Vaultの場所。既存のObsidian Vaultを使う場合は絶対パスを指定。
# 未指定なら ./vault を使います。
VAULT_PATH=./vault

# APIサーバのポート（既定 8787）。
PORT=8787

# 外部資料の鮮度警告のしきい値（日数）。既定 7。
REFRESH_ALERT_DAYS=7

# --- 以下は Phase 1.5〜2（蒸留・外部連携）で使用。今は空でOK ---

# Googleサービスアカウント鍵ファイルのパス（リポジトリ外に置くこと）。
# 付与済みSA: forclaude@forclaude-495000.iam.gserviceaccount.com（対象Sheetの読み取りのみ）
GOOGLE_APPLICATION_CREDENTIALS=

# 本人アカウント識別子（人格蒸留で「本人の発言だけ」を特定するために使用）。
# 表示名ではなくIDで固定する。
KAWASAKI_GMAIL=kawasaki@gb-jp.com
KAWASAKI_SLACK_USER_ID=
KAWASAKI_ASANA_USER_GID=

# メール読み取りの方式（Phase 1.5〜2）。Spark MCP か IMAP のどちらでも可。
# IMAP を使う場合の接続情報（アプリパスワード等。値はリポジトリ外管理）。
MAIL_METHOD=            # spark | imap
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=kawasaki@gb-jp.com
IMAP_PASSWORD=          # アプリパスワード等。絶対にコミットしない
